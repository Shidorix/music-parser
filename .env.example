PLAYLIST_PARSER_ENVIRONMENT=development
PLAYLIST_PARSER_DATABASE_URL=sqlite+aiosqlite:///./playlist_parser.db
PLAYLIST_PARSER_AUTO_CREATE_TABLES=false
PLAYLIST_PARSER_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PLAYLIST_PARSER_CONFIDENCE_THRESHOLD=0.8
PLAYLIST_PARSER_ENABLE_DEMO_PROVIDER=true
PLAYLIST_PARSER_SPOTIFY_ACCESS_TOKEN=
PLAYLIST_PARSER_SPOTIFY_MARKET=
PLAYLIST_PARSER_YOUTUBE_API_KEY=
PLAYLIST_PARSER_YOUTUBE_REGION_CODE=
PLAYLIST_PARSER_YOUTUBE_RELEVANCE_LANGUAGE=
